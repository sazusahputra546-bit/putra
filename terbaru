        // ============================================================
        // 4. GENERATOR PREDIKSI DINAMIS UNTUK SEMUA PASARAN
        // ============================================================
        function generatePrediksiDetail(nama) {
            let hash = 0;
            for (let i = 0; i < nama.length; i++) {
                hash = ((hash << 5) - hash) + nama.charCodeAt(i);
                hash = hash & hash;
            }
            hash = Math.abs(hash);

            function rng(min, max) {
                hash = (hash * 9301 + 49297) % 233280;
                return Math.floor((hash / 233280) * (max - min + 1)) + min;
            }

            function rngDigit() { return rng(0, 9); }
            function genAngka(digits) { let r = ''; for (let i = 0; i < digits; i++) r += rngDigit(); return r; }

            function genArray(count, digits) {
                let arr = [],
                    seen = new Set();
                for (let i = 0; i < count; i++) {
                    let num,
                        attempts = 0;
                    do { num = genAngka(digits);
                        attempts++; } while (seen.has(num) && attempts < 50);
                    seen.add(num);
                    arr.push(num);
                }
                return arr;
            }

