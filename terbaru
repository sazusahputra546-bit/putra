            filtered.forEach((item, idx) => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${idx + 1}</td>
                    <td class="nama-pasaran">${item.pasaran}</td>
                    <td class="isi-prediksi" title="${item.prediksi}">${item.prediksi}</td>
