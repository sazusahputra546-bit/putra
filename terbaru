                    { label: '2️⃣ 2D (BB)', value: str2d, cls: 'angka' },
                    { label: '🎲 COLOK BEBAS', value: detail.colok_bebas || '-', cls: '' },
                    { label: '🎲 COLOK BEBAS 2D', value: detail.colok_bebas_2d || '-', cls: '' },
                    { label: '🐉 SHIO', value: detail.shio || '-', cls: '' },
                    { label: '👯 TWIN', value: detail.twin || '-', cls: '' }
                ];

                let html = `<div class="sticky-note-besar">`;

                items.forEach(item => {
                    const safeValue = String(item.value).replace(/</g, '&lt;').replace(/>/g, '&gt;');
                    html += `
                        <div class="note-row">
                            <span class="note-label">${item.label}</span>
                            <span class="note-value ${item.cls}">${safeValue}</span>
                        </div>
                    `;
                });

                const note = detail.note || 'Selalu Utamakan Prediksi Sendiri';
                html += `
                        <div class="note-note">💡 ${note}</div>
                    </div>
                `;

                detailContent.innerHTML = html;
            } else {
                detailContent.innerHTML = `<div class="no-prediksi">📭 Belum ada prediksi lengkap untuk pasaran ini</div>`;
            }

            detailDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        // ============================================================
        // 14. FUNGSI COPY PREDIKSI (DIPERBAIKI)
        // ============================================================
        function copyPrediksi() {
            if (!lastPrediksiDetail) {
                alert('Tidak ada prediksi untuk disalin. Klik pasaran terlebih dahulu.');
                return;
            }

            const d = lastPrediksiDetail;
            const str4d = d['4d'] ? d['4d'].join(' ') : '-';
            const str3d = d['3d'] ? d['3d'].join(' ') : '-';
            const str2d = d['2d'] ? d['2d'].join(' ') : '-';

            // Format teks yang rapi sesuai sticky notes
            const text =
                `📊 ${lastPrediksiNama}
${'='.repeat(40)}

📅 Tanggal       : ${d.tanggal || '-'}
🔢 BBFS          : ${d.bbfs || '-'}
🎯 ANGKA MAIN    : ${d.angka_main || '-'}
4️⃣ 4D (BB)      : ${str4d}
3️⃣ 3D (BB)      : ${str3d}
2️⃣ 2D (BB)      : ${str2d}
🎲 COLOK BEBAS   : ${d.colok_bebas || '-'}
🎲 COLOK BEBAS 2D: ${d.colok_bebas_2d || '-'}
🐉 SHIO          : ${d.shio || '-'}
👯 TWIN          : ${d.twin || '-'}

💡 ${d.note || 'Selalu Utamakan Prediksi Sendiri'}`;

            // Menggunakan Clipboard API dengan fallback
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(() => {
                    btnCopy.textContent = '✅ Tersalin!';
                    btnCopy.classList.add('copied');
                    setTimeout(() => {
                        btnCopy.textContent = '📋 Copy';
                        btnCopy.classList.remove('copied');
                    }, 2000);
                }).catch(() => {
                    // Fallback jika clipboard gagal
                    copyFallback(text);
                });
            } else {
                // Fallback untuk browser yang tidak support Clipboard API
                copyFallback(text);
            }
        }

        // Fallback copy menggunakan textarea
        function copyFallback(text) {
            const textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.style.position = 'fixed';
            textarea.style.opacity = '0';
            textarea.style.left = '-9999px';
            document.body.appendChild(textarea);
            textarea.select();
            try {
                document.execCommand('copy');
                btnCopy.textContent = '✅ Tersalin!';
                btnCopy.classList.add('copied');
                setTimeout(() => {
                    btnCopy.textContent = '📋 Copy';
                    btnCopy.classList.remove('copied');
                }, 2000);
            } catch (err) {
                alert('Gagal menyalin: ' + err);
            }
            document.body.removeChild(textarea);
        }

        btnCopy.addEventListener('click', copyPrediksi);

        // ============================================================
        // 15. FUNGSI CLOSE DETAIL
        // ============================================================
        function closeDetail() {
            detailDiv.classList.remove('visible');
            lastPrediksiDetail = null;
            lastPrediksiNama = '';
        }

        btnClose.addEventListener('click', closeDetail);

        // ============================================================
        // 16. PENCARIAN
        // ============================================================
        function performSearch() {
            const keyword = searchInput.value;
            renderTabelPrediksi(keyword);
            const filtered = semuaCatatan.filter(item =>
                item.pasaran.toLowerCase().includes(keyword.toLowerCase().trim()) ||
                item.prediksi.toLowerCase().includes(keyword.toLowerCase().trim())
            );
            totalSpan.textContent = filtered.length;
            if (keyword.trim() !== '') {
                resultInfo.textContent = `Menampilkan ${filtered.length} dari ${semuaCatatan.length}`;
            } else {
                resultInfo.textContent = '';
            }
            closeDetail();
        }

        searchBtn.addEventListener('click', performSearch);
        searchInput.addEventListener('keyup', (e) => {
            if (e.key === 'Enter') performSearch();
        });

        // ============================================================
        // 17. TOGGLE PREDIKSI
        // ============================================================
        togglePrediksiBtn.addEventListener('click', function() {
            prediksiVisible = !prediksiVisible;
            if (prediksiVisible) {
                prediksiWrapper.classList.add('visible');
                this.textContent = '📋 Sembunyikan Prediksi';
                renderTabelPrediksi(searchInput.value);
            } else {
                prediksiWrapper.classList.remove('visible');
                this.textContent = '📋 Tampilkan Prediksi';
            }
        });

        // ============================================================
        // 18. INISIALISASI
        // ============================================================
        async function init() {
            await fetchDataFromSheets();
            updateBadgeWaktu();
            totalSpan.textContent = marketData.length;
            console.log('✅ Aplikasi siap.');
        }
        init();

        // ============================================================
        // 19. LOGIKA SCANNER
        // ============================================================
        trigger.addEventListener('click', () => {
            modal.classList.add('open');
            previewImg.style.display = 'none';
            resultText.textContent = 'Belum ada gambar diproses';
            resultText.className = 'text-result empty';
            loadingIndicator.style.display = 'none';
            currentImageFile = null;
            fileInput.value = '';
        });

        function closeModal() {
            modal.classList.remove('open');
        }
        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });

        dropArea.addEventListener('click', () => fileInput.click());
        dropArea.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropArea.style.borderColor = '#f5d742';
        });
        dropArea.addEventListener('dragleave', () => {
            dropArea.style.borderColor = 'rgba(255,215,0,0.12)';
        });
        dropArea.addEventListener('drop', (e) => {
            e.preventDefault();
            dropArea.style.borderColor = 'rgba(255,215,0,0.12)';
            if (e.dataTransfer.files.length) {
                const file = e.dataTransfer.files[0];
                if (file.type.startsWith('image/')) {
                    handleImageFile(file);
                } else {
                    alert('Mohon pilih file gambar.');
                }
            }
        });

        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length) {
                handleImageFile(e.target.files[0]);
            }
        });

        function handleImageFile(file) {
            currentImageFile = file;
            const reader = new FileReader();
            reader.onload = (e) => {
                previewImg.src = e.target.result;
                previewImg.style.display = 'block';
                resultText.textContent = 'Gambar siap diproses. Klik "Scan Ulang" untuk membaca teks.';
                resultText.className = 'text-result';
            };
            reader.readAsDataURL(file);
            performOCR(file);
        }

        async function performOCR(file) {
            if (!file) {
                alert('Pilih gambar terlebih dahulu.');
                return;
            }
            loadingIndicator.style.display = 'block';
            resultText.textContent = 'Memproses...';
            resultText.className = 'text-result';

            try {
                const imageUrl = URL.createObjectURL(file);
                const result = await Tesseract.recognize(imageUrl, 'ind+eng', {
                    logger: (m) => {
                        if (m.status === 'recognizing text') {}
                    }
                });
                const text = result.data.text.trim();
                if (text) {
                    resultText.textContent = text;
                    resultText.className = 'text-result';
                } else {
                    resultText.textContent = 'Tidak ada teks yang terdeteksi.';
                    resultText.className = 'text-result empty';
                }
            } catch (err) {
                console.error(err);
                resultText.textContent = 'Gagal membaca gambar: ' + err.message;
                resultText.className = 'text-result empty';
            } finally {
                loadingIndicator.style.display = 'none';
            }
        }

        scanBtn.addEventListener('click', () => {
            if (currentImageFile) {
                performOCR(currentImageFile);
            } else {
                alert('Pilih gambar terlebih dahulu dengan mengklik area di atas.');
            }
        });

        // ============================================================
        // 20. ANIMASI BINTANG JATUH (Canvas)
        // ============================================================
        (function() {
            const canvas = document.getElementById('stars-canvas');
            const ctx = canvas.getContext('2d');

            function resizeCanvas() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            window.addEventListener('resize', resizeCanvas);
            resizeCanvas();

            const fixedStars = [];
            const FIXED_STAR_COUNT = 200;
            for (let i = 0; i < FIXED_STAR_COUNT; i++) {
                fixedStars.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    radius: Math.random() * 1.5 + 0.3,
                    brightness: Math.random() * 0.7 + 0.2,
                    twinkleSpeed: Math.random() * 0.025 + 0.005,
                    phase: Math.random() * Math.PI * 2
                });
            }

            const shootingStars = [];
            const MAX_SHOOTING = 8;
            const SPAWN_RATE = 0.02;

            function resetShootingStar(star) {
                const angle = Math.random() * Math.PI * 0.7 + 0.15;
                const speed = Math.random() * 6 + 4;
                const spawnX = Math.random() * canvas.width * 0.9 + canvas.width * 0.05;
                const spawnY = Math.random() * canvas.height * 0.3;
                star.x = spawnX;
                star.y = spawnY;
                star.vx = Math.cos(angle) * speed;
                star.vy = Math.sin(angle) * speed;
                star.length = Math.random() * 70 + 30;
                star.opacity = Math.random() * 0.7 + 0.3;
                star.life = 1.0;
                star.decay = Math.random() * 0.01 + 0.005;
            }

            function initShootingStars(count) {
                for (let i = 0; i < count; i++) {
                    const star = { x: 0, y: 0, vx: 0, vy: 0, length: 0, opacity: 0, life: 0, decay: 0 };
                    resetShootingStar(star);
                    star.life = Math.random() * 0.8 + 0.2;
                    shootingStars.push(star);
                }
            }
            initShootingStars(4);

            function drawStars() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                const time = Date.now() / 1000;

                for (let s of fixedStars) {
                    const flicker = 0.6 + 0.4 * Math.sin(time * s.twinkleSpeed + s.phase);
                    const alpha = s.brightness * flicker;
                    ctx.beginPath();
                    ctx.arc(s.x, s.y, s.radius, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(255, 255, 240, ${alpha})`;
                    ctx.fill();
                    if (s.radius > 1.0) {
                        ctx.shadowColor = 'rgba(255, 235, 180, 0.15)';
                        ctx.shadowBlur = 6;
                        ctx.fill();
                        ctx.shadowBlur = 0;
                    }
                }

                if (shootingStars.length < MAX_SHOOTING && Math.random() < SPAWN_RATE) {
                    const newStar = { x: 0, y: 0, vx: 0, vy: 0, length: 0, opacity: 0, life: 0, decay: 0 };
                    resetShootingStar(newStar);
                    newStar.life = Math.random() * 0.7 + 0.3;
                    shootingStars.push(newStar);
                }

                for (let i = shootingStars.length - 1; i >= 0; i--) {
                    const s = shootingStars[i];
                    s.x += s.vx;
                    s.y += s.vy;
                    s.life -= s.decay;

                    if (s.life <= 0 || s.x > canvas.width + 100 || s.y > canvas.height + 100 || s.x < -100 || s.y < -
                        100) {
                        resetShootingStar(s);
                        s.life = Math.random() * 0.8 + 0.3;
                        continue;
                    }

                    const currentOpacity = s.opacity * s.life;
                    const endX = s.x - s.vx * s.length * 0.3;
                    const endY = s.y - s.vy * s.length * 0.3;

                    const gradient = ctx.createLinearGradient(s.x, s.y, endX, endY);
                    gradient.addColorStop(0, `rgba(255, 255, 240, ${currentOpacity})`);
                    gradient.addColorStop(0.4, `rgba(255, 210, 140, ${currentOpacity * 0.7})`);
                    gradient.addColorStop(1, `rgba(255, 200, 100, 0)`);

                    ctx.beginPath();
                    ctx.moveTo(s.x, s.y);
                    ctx.lineTo(endX, endY);
                    ctx.strokeStyle = gradient;
                    ctx.lineWidth = 1.8 + Math.random() * 0.3;
                    ctx.shadowColor = `rgba(255, 215, 120, ${currentOpacity * 0.2})`;
                    ctx.shadowBlur = 20;
                    ctx.stroke();
                    ctx.shadowBlur = 0;

                    ctx.beginPath();
                    ctx.arc(s.x, s.y, 1.2 + Math.random() * 0.5, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(255, 255, 235, ${currentOpacity * 0.8})`;
                    ctx.shadowColor = `rgba(255, 220, 150, ${currentOpacity * 0.15})`;
                    ctx.shadowBlur = 14;
                    ctx.fill();
                    ctx.shadowBlur = 0;
                }

                requestAnimationFrame(drawStars);
            }

            drawStars();

            window.addEventListener('resize', () => {
                resizeCanvas();
                for (let s of fixedStars) {
                    s.x = Math.random() * canvas.width;
                    s.y = Math.random() * canvas.height;
                }
                for (let s of shootingStars) {
                    if (s.x > canvas.width || s.y > canvas.height) {
                        resetShootingStar(s);
                        s.life = Math.random() * 0.6 + 0.4;
                    }
                }
            });
        })();

        console.log('✅ Aplikasi siap.');
    </script>

